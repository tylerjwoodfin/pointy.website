# Optional: WebSocket URL for production builds (no trailing slash).
# In development, the CRA proxy uses /pointing-showdown-ws → localhost:3333.
# Production (Cloudflare Pages build env):
# REACT_APP_POINTING_BLACKJACK_WS=wss://ws.pointy.website

# Optional: fallback port when REACT_APP_POINTING_BLACKJACK_WS is unset (non-dev).
# REACT_APP_POINTING_BLACKJACK_PORT=3333

# Required for the WebSocket server (session persistence).
# Run supabase/migrations/*.sql in your project first.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Pages function `functions/submit-feedback.ts` (feedback modal).
# RESEND_API_KEY=
# FEEDBACK_EMAIL_FROM=
# FEEDBACK_EMAIL_TO=
