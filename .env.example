# Optional: WebSocket URL for production builds (no trailing slash).
# In development, the CRA proxy uses /pointy-ws → localhost:3333.
# Production (Cloudflare Pages build env):
# REACT_APP_POINTING_BLACKJACK_WS=wss://ws.pointy.website

# Optional: fallback port when REACT_APP_POINTING_BLACKJACK_WS is unset (non-dev).
# REACT_APP_POINTING_BLACKJACK_PORT=3333

# Required for the WebSocket server (session persistence).
# Run supabase/migrations/*.sql in your project first.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Pages function `functions/submit-feedback.ts` (feedback modal).
# RESEND_API_KEY=
# FEEDBACK_EMAIL_FROM=
# FEEDBACK_EMAIL_TO=
# Bridge to this host (creates Taiga ticket; public Taiga URL is behind Authentik):
# FEEDBACK_TAIGA_PROXY_URL=https://ws.pointy.website/create-pointy-feedback
# POINTY_FEEDBACK_SECRET=generate-a-long-random-string

# WebSocket host: same POINTY_FEEDBACK_SECRET as Pages. Taiga creds default from Cabinet
# (taiga.api_root, taiga.auth_token, taiga.base_url) when unset.
# POINTY_FEEDBACK_SECRET=
# TAIGA_API_ROOT=http://172.25.0.8:8000/api/v1
# TAIGA_AUTH_TOKEN=
# TAIGA_PUBLIC_BASE_URL=https://taiga.tyler.cloud
# TAIGA_PROJECT_SLUG=tjw
# TAIGA_STATUS=New
