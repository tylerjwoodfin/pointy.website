# Example systemd unit — copy to /etc/systemd/system/pointing-blackjack.service (adjust paths/user).
#
#   sudo cp server/pointing-blackjack.service.example /etc/systemd/system/pointing-blackjack.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now pointing-blackjack
#
# Point production builds at this server with REACT_APP_POINTING_BLACKJACK_WS=wss://...

[Unit]
Description=Pointing Showdown WebSocket server
After=network.target

[Service]
Type=simple
User=YOUR_UNIX_USER
WorkingDirectory=/home/YOUR_UNIX_USER/git/pointy.website
ExecStart=/usr/bin/node server/pointing-blackjack.mjs
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=POINTING_BLACKJACK_PORT=3333
# Supabase (run supabase/migrations/20260629000000_pointing_showdown.sql first)
Environment=SUPABASE_URL=https://YOUR_PROJECT.supabase.co
Environment=SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

[Install]
WantedBy=multi-user.target
