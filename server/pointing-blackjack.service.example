# Example systemd unit — copy to /etc/systemd/system/pointing-blackjack.service (adjust paths/user).
#
#   sudo cp server/pointing-blackjack.service.example /etc/systemd/system/pointing-blackjack.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now pointing-blackjack
#
# Point production builds at this server with REACT_APP_POINTING_BLACKJACK_WS=wss://...

[Unit]
Description=Pointy WebSocket server
After=network.target

[Service]
Type=simple
User=YOUR_UNIX_USER
WorkingDirectory=/home/YOUR_UNIX_USER/git/pointy.website
ExecStart=/usr/bin/node server/pointing-blackjack.mjs
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=POINTING_BLACKJACK_PORT=3333
# Cabinet usage metrics (session start/join/vote/reveal). CLI must be on PATH
# or set CABINET_BIN — systemd often omits ~/.local/bin.
Environment=PATH=/home/YOUR_UNIX_USER/.local/bin:/usr/local/bin:/usr/bin:/bin
# Environment=CABINET_BIN=/home/YOUR_UNIX_USER/.local/bin/cabinet
# Supabase (run supabase/migrations/20260629000000_pointing_showdown.sql first)
Environment=SUPABASE_URL=https://YOUR_PROJECT.supabase.co
Environment=SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Feedback → Taiga bridge (must match Pages secret POINTY_FEEDBACK_SECRET)
# Environment=POINTY_FEEDBACK_SECRET=generate-a-long-random-string
# Optional Taiga overrides (otherwise loaded from Cabinet taiga.*):
# Environment=TAIGA_API_ROOT=http://172.25.0.8:8000/api/v1
# Environment=TAIGA_AUTH_TOKEN=
# Environment=TAIGA_PUBLIC_BASE_URL=https://taiga.tyler.cloud

[Install]
WantedBy=multi-user.target
